<!--miniprogram/pages/admin/dev/dev.wxml-->
<page-meta>
  <navigation-bar front-color="#ffffff" background-color="#487ed9" />
</page-meta>

<view class="page">

  <!-- 搜索区 -->
  <view class="search-bar card">
    <view class="search-input-wrap">
      <input
        class="search-input"
        type="text"
        value="{{id}}"
        placeholder="输入或扫描设备编号"
        placeholder-class="search-input-placeholder"
        bindinput="onIdInput"
        bindconfirm="scanRequst"
      />
      <view class="search-scan" bindtap="scanMac">📷</view>
    </view>
    <button class="search-btn" bindtap="scanRequst" disabled="{{!id}}">查询</button>
  </view>

  <!-- 设备信息卡（仅在有数据时） -->
  <view wx:if="{{hasDev}}" class="card">
    <view class="card-title">设备信息</view>
    <view class="info-list">
      <view
        wx:for="{{devInfo}}"
        wx:key="label"
        class="info-row {{index === devInfo.length - 1 ? 'info-row-last' : ''}}"
      >
        <text class="info-key">{{item.label}}</text>
        <text class="info-val {{item.empty ? 'info-val-empty' : ''}}">{{item.value}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty">
    <view class="empty-icon">📟</view>
    <view class="empty-text">输入或扫描设备编号查询</view>
    <view class="empty-hint">查询后可以查看设备注册信息并执行删除操作</view>
  </view>

  <!-- 底部固定删除按钮（仅在有数据时） -->
  <view wx:if="{{hasDev}}" class="footer-action">
    <button class="btn btn-danger btn-lg" bindtap="delRegisterDev">删除设备</button>
  </view>

</view>
