/* miniprogram/pages/admin/dev/dev.wxss */
/* 视觉规范见 docs/style-guide.md */

page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  background: #f4f7fb;
  padding-bottom: 160rpx;
}

/* === 搜索区（左右并排：左 1fr 搜索框 + 右 auto 按钮）=== */
.search-bar {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
}

.search-input-wrap {
  min-width: 0;        /* 关键：让 grid 子项可以收缩到 0，子元素才会被挤压而非撑爆 */
  position: relative;
  display: flex;
  align-items: center;
  background: #f4f7fb;
  border: 1rpx solid #e9ecf3;
  border-radius: 12rpx;
  padding: 0 16rpx;
  height: 72rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #1f2533;
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
}

.search-input-placeholder {
  color: #c0c5d2;
  font-family: -apple-system, "Helvetica Neue", sans-serif;
}

.search-scan {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
  color: #487ed9;
  margin-left: 8rpx;
}

.search-btn {
  /* 重置 button 默认样式 —— 不然小程序 button 在 grid 里会撑大 */
  margin: 0;
  padding: 0;
  border: none;
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 999rpx;
  height: 72rpx;
  line-height: 72rpx;
  white-space: nowrap;
  letter-spacing: 0;
  box-shadow: 0 4rpx 12rpx rgba(72, 126, 217, 0.25);
}

.search-btn::after {
  border: none;
}

.search-btn[disabled] {
  background: #c0c5d2;
  color: #ffffff;
  box-shadow: none;
}

/* === Card === */
.card {
  background: #ffffff;
  border: 1rpx solid #e9ecf3;
  border-radius: 16rpx;
  margin: 20rpx 20rpx 0;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(40, 60, 110, 0.05);
}

.card-title {
  font-size: 22rpx;
  color: #8a93a6;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 14rpx;
  font-weight: 500;
}

/* === Info list === */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f2f7;
  gap: 16rpx;
}

.info-row-last {
  border-bottom: none;
  padding-bottom: 4rpx;
}

.info-key {
  font-size: 26rpx;
  color: #8a93a6;
  flex-shrink: 0;
}

.info-val {
  font-size: 26rpx;
  color: #1f2533;
  font-weight: 500;
  text-align: right;
  word-break: break-all;
}

.info-val-empty {
  color: #c0c5d2;
  font-weight: 400;
}

/* === Footer action === */
.footer-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 28rpx 32rpx;
  background: linear-gradient(180deg, rgba(244,247,251,0) 0%, #f4f7fb 60%);
}

.btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  margin: 0;
  padding: 0;
  display: block;
  transition: opacity 0.1s ease;
}

.btn::after {
  border: none;
}

.btn:active {
  opacity: 0.85;
}

.btn-primary {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(72, 126, 217, 0.32);
}

.btn-danger {
  background: rgba(229, 69, 69, 0.10);
  color: #e54545;
}

.btn-lg {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
}

/* === Empty state === */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 60rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 30rpx;
  color: #3a4256;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8a93a6;
  line-height: 1.6;
}
