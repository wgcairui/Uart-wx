/* miniprogram/pages/admin/devs/devs.wxss */
/* 视觉规范见 docs/style-guide.md；与 pages/index/devs/devs.wxss 同构（admin 简化版） */

page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background: linear-gradient(to bottom, #487ed9 0%, #e9f3fb 320rpx, #f4f7fb 100%);
  background-attachment: scroll;
}

/* === Hero === */
.hero {
  position: relative;
  padding: 48rpx 32rpx 40rpx;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  z-index: 0;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-meta {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-bottom: 16rpx;
}

.hero-time {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.hero-time-icon {
  font-size: 22rpx;
  line-height: 1;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.2;
  letter-spacing: 1rpx;
  margin-bottom: 6rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 400;
}

/* === Content（白色浮在渐变上） === */
.content {
  margin: 16rpx 24rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
  background: #ffffff;
  padding-bottom: 32rpx;
}

/* === 搜索框 === */
.search-bar {
  padding: 20rpx 24rpx 4rpx;
  background: #ffffff;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f4f7fb;
  border: 1rpx solid #e9ecf3;
  border-radius: 12rpx;
  padding: 0 16rpx;
  height: 72rpx;
}

.search-icon {
  font-size: 24rpx;
  color: #8a93a6;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  color: #1f2533;
}

.search-input-placeholder {
  color: #c0c5d2;
  font-size: 26rpx;
}

/* === 参数 section head === */
.param-section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
}

.param-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2438;
}

.param-section-count {
  font-size: 22rpx;
  color: #8a93a6;
}

/* === 参数列表 === */
.param-list {
  margin: 0 24rpx;
  background: #ffffff;
  border: 1rpx solid #e9ecf3;
  border-radius: 16rpx;
  overflow: hidden;
}

.param-item {
  display: flex;
  flex-direction: column;
  padding: 26rpx 24rpx;
  border-bottom: 1rpx solid #f0f2f7;
  position: relative;
}

.param-item:last-child {
  border-bottom: none;
}

.param-item:active {
  background: #fafbfd;
}

.param-item.is-alarm {
  background: rgba(229, 69, 69, 0.04);
}

.param-item-dot {
  position: absolute;
  left: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #e54545;
  box-shadow: 0 0 0 4rpx rgba(229, 69, 69, 0.18);
}

.param-item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  width: 100%;
  padding-left: 16rpx;
}

.param-item-name {
  font-size: 28rpx;
  color: #2d3850;
  font-weight: 500;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.param-item.is-alarm .param-item-name {
  color: #e54545;
}

.param-item-value {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-size: 28rpx;
  color: #1a2438;
  font-weight: 500;
  font-family: -apple-system, "DIN Alternate", "Helvetica Neue", sans-serif;
  flex-shrink: 0;
}

.param-item-unit {
  font-size: 22rpx;
  color: #8a93a6;
  font-weight: 400;
}

.param-item-empty {
  color: #c8cdd8;
  font-weight: 400;
}

.param-item-arrow {
  font-size: 32rpx;
  line-height: 1;
  color: #c8cdd8;
  font-weight: 300;
  margin-left: 4rpx;
}

/* === Empty state === */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 60rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 30rpx;
  color: #3a4256;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8a93a6;
  line-height: 1.6;
}
