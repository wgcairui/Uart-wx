/* miniprogram/pages/admin/node/node.wxss */
/* 视觉规范见 docs/style-guide.md */

page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  background: #f4f7fb;
  padding-bottom: 40rpx;
}

/* === Hero === */
.hero {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  padding: 36rpx 28rpx 32rpx;
  color: #ffffff;
}

.hero-row {
  margin-bottom: 28rpx;
}

.hero-info {
  flex: 1;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.hero-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.88;
}

/* === KPI === */
.kpi-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.kpi {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 16rpx;
  padding: 18rpx 16rpx;
  text-align: center;
}

.kpi-num {
  font-size: 36rpx;
  font-weight: 700;
  font-family: -apple-system, "DIN Alternate", "Helvetica Neue", sans-serif;
  line-height: 1.2;
  letter-spacing: 0.5rpx;
}

.kpi-label {
  font-size: 20rpx;
  opacity: 0.85;
  margin-top: 6rpx;
  line-height: 1.2;
}

/* === Card === */
.card {
  background: #ffffff;
  border: 1rpx solid #e9ecf3;
  border-radius: 16rpx;
  margin: 20rpx 20rpx 0;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(40, 60, 110, 0.05);
}

.card-title {
  font-size: 22rpx;
  color: #8a93a6;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 14rpx;
  font-weight: 500;
}

/* === Node list === */
.node-list {
  display: flex;
  flex-direction: column;
}

.node-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f2f7;
}

.node-card-last {
  border-bottom: none;
  padding-bottom: 4rpx;
}

.node-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
  gap: 12rpx;
}

.node-name-wrap {
  flex: 1;
  min-width: 0;
}

.node-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2533;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.node-meta {
  font-size: 22rpx;
  color: #8a93a6;
  margin-top: 4rpx;
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
}

/* === Pill === */
.node-pill {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.node-pill-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.node-pill-normal {
  background: rgba(46, 207, 138, 0.12);
  color: #1aa86c;
}

.node-pill-normal .node-pill-dot {
  background: #2ecf8a;
  box-shadow: 0 0 0 3rpx rgba(46, 207, 138, 0.3);
}

.node-pill-busy {
  background: rgba(255, 213, 79, 0.18);
  color: #8a5a0e;
}

.node-pill-busy .node-pill-dot {
  background: #ffd54f;
  box-shadow: 0 0 0 3rpx rgba(255, 213, 79, 0.4);
}

.node-pill-full {
  background: rgba(229, 69, 69, 0.12);
  color: #e54545;
}

.node-pill-full .node-pill-dot {
  background: #e54545;
  box-shadow: 0 0 0 3rpx rgba(229, 69, 69, 0.3);
}

/* === Progress bar === */
.node-progress {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.node-progress-bar {
  flex: 1;
  height: 14rpx;
  background: #f0f2f7;
  border-radius: 999rpx;
  overflow: hidden;
}

.node-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.3s ease;
}

.node-progress-fill-normal {
  background: linear-gradient(135deg, #2ecf8a 0%, #1aa86c 100%);
}

.node-progress-fill-busy {
  background: linear-gradient(135deg, #ffd54f 0%, #ffa726 100%);
}

.node-progress-fill-full {
  background: linear-gradient(135deg, #e54545 0%, #c62828 100%);
}

.node-progress-label {
  font-size: 22rpx;
  color: #3a4256;
  font-weight: 500;
  flex-shrink: 0;
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
}

/* === Empty === */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 60rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 30rpx;
  color: #3a4256;
  font-weight: 500;
}
