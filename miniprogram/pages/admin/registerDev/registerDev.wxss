/* miniprogram/pages/admin/registerDev/registerDev.wxss */
/* 视觉规范见 docs/style-guide.md */

page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  background: #f4f7fb;
  padding-bottom: 160rpx;
}

/* === Hero === */
.hero {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  padding: 36rpx 28rpx 40rpx;
  color: #ffffff;
}

.hero-row {
  display: flex;
  align-items: center;
}

.hero-info {
  flex: 1;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.hero-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.88;
}

/* === Card === */
.card {
  background: #ffffff;
  border: 1rpx solid #e9ecf3;
  border-radius: 16rpx;
  margin: 20rpx 20rpx 0;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(40, 60, 110, 0.05);
}

.card-title {
  font-size: 22rpx;
  color: #8a93a6;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 14rpx;
  font-weight: 500;
}

/* === IMEI 输入区 === */
.imei-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.imei-input-wrap {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  background: #f4f7fb;
  border: 1rpx solid #e9ecf3;
  border-radius: 12rpx;
  padding: 0 16rpx;
  height: 72rpx;
}

.imei-input {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #1f2533;
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
}

.imei-input-placeholder {
  color: #c0c5d2;
  font-family: -apple-system, "Helvetica Neue", sans-serif;
}

.imei-scan {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #487ed9;
  margin-left: 8rpx;
}

/* === IDs 列表 === */
.ids-list {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f2f7;
}

.ids-list-title {
  font-size: 22rpx;
  color: #8a93a6;
  margin-bottom: 12rpx;
}

.id-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f2f7;
}

.id-row-last {
  border-bottom: none;
  padding-bottom: 4rpx;
}

.id-mono {
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
  font-size: 26rpx;
  color: #1f2533;
}

.id-remove {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #e54545;
  font-size: 28rpx;
  line-height: 1;
}

/* === Picker list === */
.picker-list {
  display: flex;
  flex-direction: column;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #f0f2f7;
  background: transparent;
}

.picker-row[disabled] {
  opacity: 0.6;
}

.picker-row-last {
  border-bottom: none;
  padding-bottom: 4rpx;
}

.picker-key {
  font-size: 28rpx;
  color: #1f2533;
  font-weight: 500;
  flex-shrink: 0;
}

.picker-val-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  justify-content: flex-end;
  min-width: 0;
}

.picker-val {
  font-size: 26rpx;
  color: #3a4256;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 360rpx;
  text-align: right;
}

.picker-val-empty {
  color: #c0c5d2;
}

.picker-arrow {
  color: #c0c5d2;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 300;
}

/* === PID input === */
.pid-input-wrap {
  display: flex;
  align-items: center;
  background: #f4f7fb;
  border: 1rpx solid #e9ecf3;
  border-radius: 8rpx;
  padding: 0 12rpx;
  height: 56rpx;
  width: 200rpx;
}

.pid-input {
  width: 100%;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 28rpx;
  color: #1f2533;
  text-align: center;
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
  font-weight: 600;
}

.pid-input-placeholder {
  color: #c0c5d2;
  font-size: 24rpx;
  font-weight: 400;
}

/* === Footer action === */
.footer-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 28rpx 32rpx;
  background: linear-gradient(180deg, rgba(244,247,251,0) 0%, #f4f7fb 60%);
}

.btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  margin: 0;
  padding: 0;
  display: block;
  transition: opacity 0.1s ease;
}

.btn::after {
  border: none;
}

.btn:active {
  opacity: 0.85;
}

.btn-primary {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(72, 126, 217, 0.32);
}

.btn-secondary {
  background: #eef3fb;
  color: #3158b8;
}

.btn-danger {
  background: rgba(229, 69, 69, 0.10);
  color: #e54545;
}

.btn-sm {
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  flex: 0 0 auto;
  padding: 0 28rpx;
}

.btn-lg {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
}

.btn[disabled] {
  opacity: 0.5;
  box-shadow: none;
}
