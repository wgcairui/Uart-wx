<!--miniprogram/pages/admin/registerDev/registerDev.wxml-->
<page-meta>
  <navigation-bar front-color="#ffffff" background-color="#487ed9" />
</page-meta>

<view class="page">

  <!-- Hero -->
  <view class="hero">
    <view class="hero-row">
      <view class="hero-info">
        <view class="hero-title">批量登记设备</view>
        <view class="hero-sub">先扫/输入 IMEI，再选设备参数，一次性提交</view>
      </view>
    </view>
  </view>

  <!-- IMEI 输入区 -->
  <view class="card">
    <view class="card-title">IMEI</view>
    <view class="imei-bar">
      <view class="imei-input-wrap">
        <input
          class="imei-input"
          type="text"
          value="{{id}}"
          placeholder="输入或扫描设备 IMEI"
          placeholder-class="imei-input-placeholder"
          bindinput="onIdInput"
          bindconfirm="onIdConfirm"
        />
        <view class="imei-scan" bindtap="scanMac">📷</view>
      </view>
      <button class="btn btn-primary btn-sm" bindtap="addId" disabled="{{!showAddBtn}}">加入列表</button>
    </view>

    <view wx:if="{{ids.length > 0}}" class="ids-list">
      <view class="ids-list-title">已录入 {{ids.length}} 个</view>
      <view
        wx:for="{{ids}}"
        wx:key="*this"
        class="id-row {{index === ids.length - 1 ? 'id-row-last' : ''}}"
      >
        <text class="id-mono">{{item}}</text>
        <view class="id-remove" data-key="{{item}}" bindtap="rmid">✕</view>
      </view>
    </view>
  </view>

  <!-- 设备参数 -->
  <view class="card">
    <view class="card-title">设备参数</view>
    <view class="picker-list">
      <picker
        class="picker-row"
        bindchange="onTypeChange"
        value="{{devTypeIndex}}"
        range="{{devTypes}}"
        range-key="text"
      >
        <text class="picker-key">设备类型</text>
        <view class="picker-val-wrap">
          <text class="picker-val">{{devTypes[devTypeIndex].text || '请选择'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
      <picker
        class="picker-row"
        bindchange="onModalChange"
        value="{{devModalIndex}}"
        range="{{devModals}}"
        range-key="text"
        disabled="{{devModals.length === 0}}"
      >
        <text class="picker-key">设备型号</text>
        <view class="picker-val-wrap">
          <text class="picker-val {{devModalIndex < 0 ? 'picker-val-empty' : ''}}">{{devModals[devModalIndex].text || '请先选设备类型'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
      <picker
        class="picker-row"
        bindchange="onProtocolChange"
        value="{{devProtocolIndex}}"
        range="{{devProtocols}}"
        range-key="text"
        disabled="{{devProtocols.length === 0}}"
      >
        <text class="picker-key">设备协议</text>
        <view class="picker-val-wrap">
          <text class="picker-val {{devProtocolIndex < 0 ? 'picker-val-empty' : ''}}">{{devProtocols[devProtocolIndex].text || '请先选设备型号'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
      <view class="picker-row picker-row-last">
        <text class="picker-key">设备地址 (PID)</text>
        <view class="pid-input-wrap">
          <input
            class="pid-input"
            type="number"
            value="{{pid}}"
            placeholder="1-255"
            placeholder-class="pid-input-placeholder"
            bindinput="onPidInput"
          />
        </view>
      </view>
    </view>
  </view>

  <!-- 底部提交按钮 -->
  <view class="footer-action">
    <button class="btn btn-primary btn-lg" bindtap="submit" disabled="{{!isReady}}">提交登记</button>
  </view>

</view>
