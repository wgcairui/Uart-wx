<!--miniprogram/pages/admin/index.wxml-->
<page-meta>
  <navigation-bar front-color="#ffffff" background-color="#487ed9" />
</page-meta>

<view class="page">

  <!-- === Hero === -->
  <view class="hero">
    <view class="hero-row">
      <button
        class="hero-avatar"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
        hover-class="none"
      >
        <image wx:if="{{avanter}}" class="hero-avatar-img" src="{{avanter}}" mode="aspectFill" />
        <view wx:else class="hero-avatar-placeholder">{{name ? name[0] : '?'}}</view>
        <view class="hero-avatar-edit">编辑</view>
      </button>
      <view class="hero-info">
        <view class="hero-name-row">
          <view class="hero-name">{{name || '管理员'}}</view>
          <view wx:if="{{role === 'admin'}}" class="hero-badge hero-badge-admin">管理员</view>
        </view>
        <view class="hero-meta">
          <text class="hero-meta-icon">📅</text>
          <text>注册于 {{rgTime || '—'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- === 账号信息 === -->
  <view class="card profile-card">
    <view class="card-title">账号信息</view>
    <view class="profile-list">
      <view class="profile-row">
        <text class="profile-key">名称</text>
        <text class="profile-val">{{name || '—'}}</text>
      </view>
      <view class="profile-row">
        <text class="profile-key">角色</text>
        <text class="profile-val">{{role || '—'}}</text>
      </view>
      <view class="profile-row profile-row-last">
        <text class="profile-key">注册时间</text>
        <text class="profile-val">{{rgTime || '—'}}</text>
      </view>
    </view>
  </view>

  <!-- === 菜单 sections === -->
  <view class="sections">
    <block wx:for="{{menuSections}}" wx:for-item="section" wx:key="id">
      <view class="card section-card">
        <view class="card-title">{{section.title}}</view>
        <view class="menu-list">
          <view
            wx:for="{{section.items}}"
            wx:for-item="item"
            wx:key="id"
            class="menu-row {{item.danger ? 'is-danger' : ''}} {{index === section.items.length - 1 ? 'menu-row-last' : ''}}"
            data-url="{{item.url}}"
            data-bindtap="{{item.bindtap}}"
            bindtap="onMenuTap"
          >
            <view class="menu-icon">{{item.icon}}</view>
            <text class="menu-label">{{item.label}}</text>
            <text wx:if="{{item.desc}}" class="menu-desc">{{item.desc}}</text>
            <text class="menu-arrow">›</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="footer">ladisuart · admin · v{{appVersion}}</view>

</view>
