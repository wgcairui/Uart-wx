/* miniprogram/pages/admin/scan/scan.wxss */
/* 视觉规范见 docs/style-guide.md */

page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  background: #f4f7fb;
  padding-bottom: 60rpx;
}

/* === 搜索区（左右并排：左 1fr 搜索框 + 右 auto 按钮）=== */
.search-bar {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
}

.search-input-wrap {
  min-width: 0;        /* 关键：让 grid 子项可以收缩到 0，子元素才会被挤压而非撑爆 */
  position: relative;
  display: flex;
  align-items: center;
  background: #f4f7fb;
  border: 1rpx solid #e9ecf3;
  border-radius: 12rpx;
  padding: 0 16rpx;
  height: 72rpx;
}

.search-input {
  flex: 1;
  min-width: 0;        /* 让 input 可以比 placeholder 短，配合 ellipsis 截断 */
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #1f2533;
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
}

.search-input-placeholder {
  color: #c0c5d2;
  font-family: -apple-system, "Helvetica Neue", sans-serif;
}

.search-scan {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
  color: #487ed9;
  margin-left: 8rpx;
}

.search-btn {
  /* 重置 button 默认样式（margin / border / 字符间距）—— 不然小程序 button 在 grid 里会撑大 */
  margin: 0;
  padding: 0 24rpx;
  border: none;
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 8rpx;
  height: 72rpx;
  line-height: 72rpx;
  white-space: nowrap;
  letter-spacing: 0;
  box-shadow: 0 4rpx 12rpx rgba(72, 126, 217, 0.25);
}

.search-btn::after {
  border: none;
}

.search-btn[disabled] {
  background: #c0c5d2;
  color: #ffffff;
  box-shadow: none;
}

/* === 历史 chip === */
.history {
  padding: 20rpx 24rpx;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  background: #f4f7fb;
  color: #3a4256;
  border-radius: 999rpx;
  border: 1rpx solid #e9ecf3;
  line-height: 1.2;
}

.chip.is-active {
  background: rgba(72, 126, 217, 0.10);
  color: #3158b8;
  border-color: rgba(72, 126, 217, 0.30);
}

/* === Hero === */
.hero {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  padding: 36rpx 28rpx 40rpx;
  color: #ffffff;
}

.hero-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.hero-info {
  flex: 1;
  min-width: 0;
}

.hero-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.hero-name {
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  max-width: 360rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  opacity: 0.88;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.hero-meta-icon {
  font-size: 22rpx;
  line-height: 1;
}

.hero-meta-mono {
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
  letter-spacing: 1rpx;
}

/* === Dev pill === */
.dev-pill {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.dev-pill.is-online {
  background: rgba(46, 207, 138, 0.22);
  color: #bdf3d4;
}

.dev-pill.is-offline {
  background: rgba(255, 213, 79, 0.22);
  color: #fff3c0;
}

.dev-pill-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.dev-pill.is-online .dev-pill-dot {
  background: #bdf3d4;
  box-shadow: 0 0 0 3rpx rgba(189, 243, 212, 0.4);
}

.dev-pill.is-offline .dev-pill-dot {
  background: #fff3c0;
  box-shadow: 0 0 0 3rpx rgba(255, 243, 192, 0.4);
}

/* === Card === */
.card {
  background: #ffffff;
  border: 1rpx solid #e9ecf3;
  border-radius: 16rpx;
  margin: 20rpx 20rpx 0;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(40, 60, 110, 0.05);
}

.card-title {
  font-size: 22rpx;
  color: #8a93a6;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 14rpx;
  font-weight: 500;
}

/* === Info list（key-value） === */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f2f7;
  gap: 16rpx;
}

.info-row-last {
  border-bottom: none;
  padding-bottom: 4rpx;
}

.info-key {
  font-size: 26rpx;
  color: #8a93a6;
  flex-shrink: 0;
}

.info-val {
  font-size: 26rpx;
  color: #1f2533;
  font-weight: 500;
  text-align: right;
  word-break: break-all;
}

.info-val-empty {
  color: #c0c5d2;
  font-weight: 400;
}

/* === Flow bar === */
.flow-bar-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: #f4f7fb;
  border-radius: 12rpx;
}

.flow-bar {
  flex: 1;
  height: 16rpx;
  background: #e9ecf3;
  border-radius: 999rpx;
  overflow: hidden;
}

.flow-bar-fill {
  height: 100%;
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  border-radius: 999rpx;
  transition: width 0.3s ease;
}

.flow-bar-label {
  font-size: 22rpx;
  color: #3a4256;
  font-weight: 500;
  flex-shrink: 0;
}

/* === Actions（操作按钮区） === */
.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 20rpx 24rpx;
}

.actions-row {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  margin: 0;
  padding: 0;
  display: block;
  transition: opacity 0.1s ease;
}

.btn::after {
  border: none;
}

.btn:active {
  opacity: 0.85;
}

.btn-primary {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(72, 126, 217, 0.25);
}

.btn-secondary {
  background: #eef3fb;
  color: #3158b8;
}

.btn-danger {
  background: rgba(229, 69, 69, 0.10);
  color: #e54545;
}

.btn-sm {
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  flex: 0 0 auto;
  padding: 0 28rpx;
}

/* === Mount card（挂载设备） === */
.mount-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mount-card {
  background: #f4f7fb;
  border: 1rpx solid #e9ecf3;
  border-radius: 14rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.mount-card-first,
.mount-card {
  margin-top: 16rpx;
}

.mount-card-first {
  margin-top: 0;
}

.mount-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.mount-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.mount-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 10rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.mount-name-wrap {
  flex: 1;
  min-width: 0;
}

.mount-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2533;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mount-type {
  font-size: 22rpx;
  color: #8a93a6;
  margin-top: 4rpx;
}

.mount-info {
  display: flex;
  flex-direction: column;
  padding: 12rpx 0;
  border-top: 1rpx solid #e9ecf3;
  border-bottom: 1rpx solid #e9ecf3;
  margin-bottom: 16rpx;
}

.mount-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
  gap: 12rpx;
}

.mount-info-key {
  font-size: 24rpx;
  color: #8a93a6;
  flex-shrink: 0;
}

.mount-info-val {
  font-size: 24rpx;
  color: #1f2533;
  font-weight: 500;
  text-align: right;
  word-break: break-all;
}

.mount-info-mono {
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
}

.mount-actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
}

/* === Empty state === */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 60rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 30rpx;
  color: #3a4256;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8a93a6;
  line-height: 1.6;
}
