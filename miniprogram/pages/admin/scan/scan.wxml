<!--miniprogram/pages/admin/scan/scan.wxml-->
<page-meta>
  <navigation-bar front-color="#ffffff" background-color="#487ed9" />
</page-meta>

<view class="page">

  <!-- === 搜索区（常驻顶部） === -->
  <view class="search-bar card">
    <view class="search-input-wrap">
      <input
        class="search-input"
        type="text"
        value="{{mac}}"
        placeholder="输入或扫描 DTU 的编号"
        placeholder-class="search-input-placeholder"
        bindinput="onMacInput"
        bindconfirm="scanRequst"
      />
      <view class="search-scan" bindtap="scanMac">📷</view>
    </view>
    <button class="search-btn" bindtap="scanRequst" disabled="{{!mac}}">查询</button>
  </view>

  <!-- === 历史查询记录 chip === -->
  <view wx:if="{{macs.length > 0}}" class="history card">
    <view class="card-title">历史查询</view>
    <view class="chips">
      <view
        wx:for="{{macs}}"
        wx:key="*this"
        class="chip {{item === mac ? 'is-active' : ''}}"
        id="{{item}}"
        bindtap="search"
      >{{item}}</view>
    </view>
  </view>

  <!-- === 设备信息（仅在有数据时显示） === -->
  <block wx:if="{{terminal.DevMac}}">

    <!-- Hero -->
    <view class="hero">
      <view class="hero-row">
        <view class="hero-info">
          <view class="hero-name-row">
            <view class="hero-name">{{terminal.name || '未命名 DTU'}}</view>
            <view class="dev-pill {{terminal.online ? 'is-online' : 'is-offline'}}">
              <view class="dev-pill-dot"></view>
              <text>{{terminal.onlineLabel}}</text>
            </view>
          </view>
          <view class="hero-meta">
            <text class="hero-meta-icon">📡</text>
            <text class="hero-meta-mono">{{terminal.DevMac}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 设备信息卡 -->
    <view class="card">
      <view class="card-title">设备信息</view>
      <view class="info-list">
        <view
          wx:for="{{terminalInfo}}"
          wx:key="label"
          class="info-row {{index === terminalInfo.length - 1 ? 'info-row-last' : ''}}"
        >
          <text class="info-key">{{item.label}}</text>
          <text class="info-val {{item.empty ? 'info-val-empty' : ''}}">{{item.value}}</text>
        </view>
      </view>
    </view>

    <!-- 物联卡信息卡（仅在有 iccidInfo 时） -->
    <view wx:if="{{hasIccid}}" class="card">
      <view class="card-title">物联卡信息</view>

      <!-- 流量使用比例条 -->
      <view class="flow-bar-wrap">
        <view class="flow-bar">
          <view class="flow-bar-fill" style="width: {{iccidFlowPercent}}%;"></view>
        </view>
        <text class="flow-bar-label">已用 {{iccidFlowPercent}}%</text>
      </view>

      <view class="info-list">
        <view
          wx:for="{{iccidInfo}}"
          wx:key="label"
          class="info-row {{index === iccidInfo.length - 1 ? 'info-row-last' : ''}}"
        >
          <text class="info-key">{{item.label}}</text>
          <text class="info-val">{{item.value}}</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮区 -->
    <view class="card actions">
      <view class="actions-row">
        <button class="btn btn-primary" bindtap="bindDevId">📎 绑定设备 Id</button>
        <button class="btn btn-secondary" bindtap="modifyUart">⚙ 修改波特率</button>
      </view>
      <view class="actions-row">
        <button class="btn btn-secondary" bindtap="resetDtu">↻ 重启设备</button>
        <button class="btn btn-secondary" bindtap="iotRemoteUrl">🔗 远程调试</button>
      </view>
      <button class="btn btn-danger" bindtap="initTerminal">⚠ 初始化设备</button>
    </view>

    <!-- 挂载设备列表 -->
    <view wx:if="{{mountDevCards.length > 0}}" class="card">
      <view class="card-title">挂载设备（{{mountDevCards.length}}）</view>
      <view class="mount-list">
        <view
          wx:for="{{mountDevCards}}"
          wx:key="pid"
          wx:for-item="card"
          class="mount-card {{index === mountDevCards.length - 1 ? 'mount-card-last' : ''}}"
        >
          <view class="mount-head">
            <view class="mount-title">
              <view class="mount-icon">📟</view>
              <view class="mount-name-wrap">
                <view class="mount-name">{{card.mountDev}}</view>
                <view class="mount-type">{{card.type}} · 协议 {{card.protocol}}</view>
              </view>
            </view>
            <view class="dev-pill {{card.online ? 'is-online' : 'is-offline'}}">
              <view class="dev-pill-dot"></view>
              <text>{{card.onlineLabel}}</text>
            </view>
          </view>
          <view class="mount-info">
            <view class="mount-info-row">
              <text class="mount-info-key">地址</text>
              <text class="mount-info-val mount-info-mono">{{card.pid}}</text>
            </view>
            <view class="mount-info-row">
              <text class="mount-info-key">设备 Id</text>
              <text class="mount-info-val mount-info-mono">{{card.bindDev}}</text>
            </view>
          </view>
          <view class="mount-actions">
            <button class="btn btn-secondary btn-sm" data-item="{{card.raw}}" bindtap="see">查看</button>
            <button class="btn btn-danger btn-sm" data-item="{{card.raw}}" bindtap="rmBind">删除</button>
          </view>
        </view>
      </view>
    </view>

  </block>

  <!-- 空状态 -->
  <view wx:else class="empty">
    <view class="empty-icon">📡</view>
    <view class="empty-text">输入或扫描 DTU 编号查询</view>
    <view class="empty-hint">查询后可以看到 DTU 详细信息、挂载设备、物联卡流量等</view>
  </view>

</view>
