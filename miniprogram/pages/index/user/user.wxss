/* miniprogram/pages/index/user/user.wxss */
page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  background: #f4f7fb;
  padding-bottom: 60rpx;
}

/* === Hero === */
.hero {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  padding: 36rpx 28rpx 40rpx;
  color: #ffffff;
}

.hero-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.hero-avatar {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  flex-shrink: 0;
}

.hero-avatar-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.25);
  display: block;
}

.hero-avatar-placeholder {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 4rpx solid rgba(255, 255, 255, 0.25);
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  text-transform: uppercase;
}

.hero-avatar-edit {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  background: #ffffff;
  color: #3158b8;
  font-size: 18rpx;
  line-height: 1;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.18);
  font-weight: 500;
}

.hero-info {
  flex: 1;
  min-width: 0;
}

.hero-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.hero-name {
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  max-width: 360rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-badge {
  font-size: 20rpx;
  padding: 3rpx 12rpx;
  border-radius: 999rpx;
  line-height: 1.3;
  font-weight: 500;
}

.hero-badge-test {
  background: #ffd54f;
  color: #8a5a0e;
}

.hero-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  opacity: 0.88;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.hero-meta-icon {
  font-size: 22rpx;
  line-height: 1;
}

/* === Card base === */
.card {
  background: #ffffff;
  border: 1rpx solid #e9ecf3;
  border-radius: 16rpx;
  margin: 20rpx 20rpx 0;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(40, 60, 110, 0.05);
}

.card-title {
  font-size: 22rpx;
  color: #8a93a6;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 14rpx;
  font-weight: 500;
}

/* === Profile (账号信息) === */
.profile-list {
  display: flex;
  flex-direction: column;
}

.profile-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f2f7;
}

.profile-row-last {
  border-bottom: none;
  padding-bottom: 4rpx;
}

.profile-key {
  font-size: 26rpx;
  color: #8a93a6;
}

.profile-val {
  font-size: 26rpx;
  color: #1f2533;
  font-weight: 500;
  max-width: 380rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* === Sections === */
.sections {
  margin-top: 0;
}

.section-card {
  padding: 20rpx 0 8rpx;
}

.section-card .card-title {
  padding: 0 24rpx 14rpx;
  margin-bottom: 0;
  border-bottom: 1rpx solid #f0f2f7;
}

/* === Menu list === */
.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-row {
  display: flex;
  align-items: center;
  padding: 26rpx 24rpx;
  border-bottom: 1rpx solid #f0f2f7;
  transition: background 0.1s ease;
}

.menu-row-last {
  border-bottom: none;
}

.menu-row:active {
  background: #f4f7fb;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  background: #eef3fb;
  color: #487ed9;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
  line-height: 1;
}

.menu-row.is-danger .menu-icon {
  background: rgba(229, 69, 69, 0.10);
  color: #e54545;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #1f2533;
  font-weight: 500;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.menu-row.is-danger .menu-label {
  color: #e54545;
}

.menu-desc {
  font-size: 24rpx;
  color: #8a93a6;
  margin-right: 12rpx;
  max-width: 220rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.menu-arrow {
  color: #c0c5d2;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 300;
  flex-shrink: 0;
}

.menu-row.is-danger .menu-arrow {
  color: rgba(229, 69, 69, 0.5);
}

/* === Footer === */
.footer {
  text-align: center;
  padding: 36rpx 0 12rpx;
  color: #c0c5d2;
  font-size: 20rpx;
  letter-spacing: 1rpx;
}
