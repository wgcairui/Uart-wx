/* miniprogram/pages/index/index.wxss */
page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  background: #f4f7fb;
  padding-bottom: 60rpx;
}

/* === Hero === */
.hero {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  padding: 36rpx 28rpx 32rpx;
  color: #ffffff;
}

.hero-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.hero-actions {
  display: flex;
  gap: 14rpx;
}

.hero-icon-btn {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.hero-icon-btn:active {
  background: rgba(255, 255, 255, 0.25);
}

.hero-icon-text {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 2rpx;
  color: #ffffff;
  margin-top: -2rpx;
}

.hero-icon-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #ffffff;
}

/* === KPI === */
.kpi-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.kpi {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 16rpx;
  padding: 18rpx 16rpx;
  text-align: center;
}

.kpi:active {
  background: rgba(255, 255, 255, 0.22);
}

.kpi-num {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.1;
  font-family: -apple-system, "DIN Alternate", "Helvetica Neue", sans-serif;
  color: #ffffff;
}

.kpi-num.is-alarm {
  color: #ffd54f;
}

.kpi-label {
  font-size: 20rpx;
  opacity: 0.85;
  margin-top: 6rpx;
}

/* === Subscribe hint === */
.subscribe-hint {
  margin: 20rpx 20rpx 0;
  padding: 16rpx 20rpx;
  background: #fff8e1;
  border-left: 6rpx solid #f0a020;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #8a5a0e;
  box-shadow: 0 2rpx 8rpx rgba(240, 160, 32, 0.10);
}

.subscribe-hint:active {
  background: #fff3c4;
}

.subscribe-hint-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.subscribe-hint-text {
  flex: 1;
  color: #5a4a1c;
}

.subscribe-hint-action {
  color: #d97e00;
  font-weight: 600;
  flex-shrink: 0;
}

/* === Tab wrapper === */
.tab {
  margin-top: 16rpx;
}

::-webkit-scrollbar {
  display: none;
}

/* === Empty state === */
.trial {
  min-height: 200px;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* === 单列设备卡片 === */
.devs {
  padding: 8rpx 0 24rpx;
}

.dev-card {
  position: relative;
  display: flex;
  align-items: stretch;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin: 20rpx 0 0;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 4rpx 20rpx rgba(40, 60, 110, 0.06);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.dev-card:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 8rpx rgba(40, 60, 110, 0.12);
}

.dev-card-status {
  width: 6rpx;
  flex-shrink: 0;
  background: #d0d6e0;
}

.dev-card.is-online .dev-card-status {
  background: linear-gradient(180deg, #2ecf8a 0%, #1aa86c 100%);
}

.dev-card.is-offline .dev-card-status {
  background: linear-gradient(180deg, #ff6b6b 0%, #e54545 100%);
}

.dev-card-main {
  flex: 1;
  min-width: 0;
  padding: 22rpx 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  border-right: 1rpx solid #f0f2f7;
}

.dev-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.dev-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  flex: 1;
}

.dev-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  background: #eef3fb;
  color: #487ed9;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.dev-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2438;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dev-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  flex-shrink: 0;
  font-weight: 500;
}

.dev-pill.is-online {
  background: rgba(46, 207, 138, 0.12);
  color: #1aa86c;
}

.dev-pill.is-offline {
  background: rgba(229, 69, 69, 0.12);
  color: #e54545;
}

.dev-pill-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.dev-pill.is-online .dev-pill-dot {
  background: #2ecf8a;
}

.dev-pill.is-offline .dev-pill-dot {
  background: #e54545;
}

.dev-card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 20rpx;
}

.dev-meta-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-size: 24rpx;
  min-width: 0;
}

.dev-meta-label {
  color: #8a93a6;
  font-size: 22rpx;
  flex-shrink: 0;
}

.dev-meta-value {
  color: #2d3850;
  font-weight: 500;
  max-width: 280rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dev-card-foot {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #a8b0bf;
  margin-top: 2rpx;
}

.dev-time {
  color: #a8b0bf;
}

.dev-card-pic {
  width: 140rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: linear-gradient(135deg, #fafbfd 0%, #f1f4f9 100%);
}

/* 统一图片容器：真实图 / 占位 icon 共用同一布局（无背景） */
.dev-pic-box {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.dev-pic-img {
  width: 100rpx;
  height: 100rpx;
}

@import "./index.skeleton.wxss";
