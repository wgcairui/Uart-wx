/* miniprogram/pages/index/devs/devs.wxss */
page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background: linear-gradient(to bottom, #487ed9 0%, #e9f3fb 320rpx, #f4f7fb 100%);
  background-attachment: scroll;
}

/* === Hero 顶部状态卡 === */
.hero {
  position: relative;
  padding: 48rpx 32rpx 40rpx;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  z-index: 0;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.hero-status {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 18rpx;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(20rpx);
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1;
}

.hero-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #2ecf8a;
  box-shadow: 0 0 0 4rpx rgba(46, 207, 138, 0.35);
  animation: pulse-online 2s ease-in-out infinite;
}

@keyframes pulse-online {
  0%, 100% { box-shadow: 0 0 0 4rpx rgba(46, 207, 138, 0.35); }
  50% { box-shadow: 0 0 0 10rpx rgba(46, 207, 138, 0.05); }
}

.hero-time {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.hero-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.2;
  letter-spacing: 1rpx;
  margin-bottom: 6rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 400;
}

/* === 内容区（白色浮在渐变上） === */
.content {
  margin: 16rpx 24rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
}

/* === 搜索栏 === */
.search-bar {
  background: #ffffff;
  padding: 0;
}

/* === 设备图卡 === */
.device-pic {
  margin-bottom: 8rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 280rpx;
  padding: 32rpx;
}

.device-pic image {
  width: 100%;
  max-height: 320rpx;
}

.device-pic-ac {
  background: linear-gradient(135deg, #f0f4ff 0%, #dde7ff 100%);
}

.device-pic-ups {
  background: linear-gradient(135deg, #fafbfd 0%, #f1f4f9 100%);
}

.device-pic-th {
  background: linear-gradient(135deg, #fff5e6 0%, #ffe4c2 100%);
  display: flex;
  align-items: stretch;
  justify-content: space-around;
  padding: 40rpx 32rpx;
  gap: 24rpx;
}

/* === 温湿度 === */
.th-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.th-block image {
  width: 80rpx;
  height: 80rpx;
}

.th-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #1a2438;
  line-height: 1.1;
  font-family: -apple-system, "DIN Alternate", "Helvetica Neue", sans-serif;
}

.th-unit {
  font-size: 24rpx;
  font-weight: 400;
  color: #8a93a6;
  margin-left: 4rpx;
}

.th-label {
  font-size: 22rpx;
  color: #8a93a6;
  letter-spacing: 2rpx;
}

.th-divider {
  width: 2rpx;
  background: rgba(0, 0, 0, 0.06);
}

/* === 参数区 === */
.param-section {
  background: transparent;
  padding: 0 24rpx 24rpx;
}

.param-section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 24rpx 8rpx 16rpx;
}

.param-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2438;
}

.param-section-count {
  font-size: 22rpx;
  color: #8a93a6;
}

.param-card {
  margin: 0 24rpx 16rpx;
  background: #fafbfd;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.param-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.param-card-label {
  font-size: 28rpx;
  color: #1a2438;
  font-weight: 500;
}

.param-list {
  margin: 0 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(40, 60, 110, 0.04);
}

.param-item {
  display: flex;
  flex-direction: column;
  padding: 26rpx 24rpx;
  border-bottom: 1rpx solid #f0f2f7;
  position: relative;
}

.param-item.is-enum {
  flex-direction: column;
  align-items: stretch;
}

.param-item:last-child {
  border-bottom: none;
}

.param-item:active {
  background: #fafbfd;
}

.param-item.is-alarm {
  background: rgba(229, 69, 69, 0.04);
}

.param-item-dot {
  position: absolute;
  left: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #e54545;
  box-shadow: 0 0 0 4rpx rgba(229, 69, 69, 0.18);
}

.param-item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-left: 16rpx;
}

.param-item-name {
  font-size: 28rpx;
  color: #2d3850;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.param-item.is-alarm .param-item-name {
  color: #e54545;
}

.param-item-hint {
  font-size: 22rpx;
  color: #8a93a6;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.param-item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  width: 100%;
}

.param-item-value {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-size: 28rpx;
  color: #1a2438;
  font-weight: 500;
  font-family: -apple-system, "DIN Alternate", "Helvetica Neue", sans-serif;
  flex-shrink: 0;
}

/* === 枚举 pill === */
.enum-pills {
  margin-top: 16rpx;
  margin-left: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.enum-pill {
  padding: 10rpx 22rpx;
  font-size: 24rpx;
  color: #2d3850;
  background: #f0f2f7;
  border-radius: 999rpx;
  line-height: 1;
  border: 2rpx solid transparent;
  transition: all 0.15s ease;
}

.enum-pill.is-active {
  background: rgba(72, 126, 217, 0.12);
  color: #487ed9;
  border-color: #487ed9;
  font-weight: 500;
}

.enum-pill:active {
  transform: scale(0.96);
}

.param-item-unit {
  font-size: 22rpx;
  color: #8a93a6;
  font-weight: 400;
}

.param-item-empty {
  color: #c8cdd8;
  font-weight: 400;
}

/* === 旧 th-pic 兼容（保留） === */
.th-pic {
  display: flex;
  margin-top: 32rpx;
  margin-bottom: 32rpx;
}

.th-pic view {
  width: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.th-pic image {
  width: 100rpx;
  height: 100rpx;
}

/* 2026-07-01 (决策 18): 定时任务入口卡片 */
.scheduled-op-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 0 24rpx 16rpx;
  padding: 24rpx 24rpx;
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
  border: 1rpx solid #ffb84d;
  border-radius: 16rpx;
}

.scheduled-op-icon {
  font-size: 40rpx;
  line-height: 1;
}

.scheduled-op-body {
  flex: 1;
  min-width: 0;
}

.scheduled-op-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2329;
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.scheduled-op-title .beta-tag {
  font-size: 20rpx;
  background: #ffb84d;
  color: #fff;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.scheduled-op-sub {
  font-size: 22rpx;
  color: #8a6300;
}

.scheduled-op-arrow {
  font-size: 36rpx;
  color: #c9cdd4;
  font-weight: 300;
}
