/* miniprogram/pages/index/scheduledOp/scheduledOp.wxss */

.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: 40rpx;
}

/* 🧪 测试版 banner */
.beta-banner {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin: 24rpx 24rpx 16rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
  border: 1rpx solid #ffb84d;
  border-radius: 12rpx;
}

.beta-icon {
  font-size: 36rpx;
  line-height: 1;
  margin-top: 2rpx;
}

.beta-text {
  flex: 1;
  min-width: 0;
}

.beta-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #874c00;
  margin-bottom: 4rpx;
}

.beta-sub {
  font-size: 24rpx;
  color: #8a6300;
  line-height: 1.4;
}

/* 主内容 */
.content {
  padding: 0 24rpx;
}

/* 创建入口卡片 */
.create-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  background: #fff;
  border: 1rpx solid #e8eaec;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.create-icon {
  width: 64rpx;
  height: 64rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 44rpx;
  font-weight: 300;
  color: #fff;
  background: #487ed9;
  border-radius: 50%;
  flex-shrink: 0;
}

.create-text {
  flex: 1;
  min-width: 0;
}

.create-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1f2329;
  margin-bottom: 4rpx;
}

.create-sub {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.4;
}

.create-arrow {
  font-size: 40rpx;
  color: #c9cdd4;
  font-weight: 300;
}

/* 状态文字 */
.state {
  padding: 80rpx 0;
  text-align: center;
  color: #8f959e;
  font-size: 28rpx;
}

/* 列表 */
.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  background: #fff;
  border: 1rpx solid #e8eaec;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-protocol {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.proto-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}

.pid {
  font-size: 22rpx;
  color: #8f959e;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.status-PENDING {
  background: #e6f4ff;
  color: #1677ff;
}

.status-RUNNING {
  background: #fff7e6;
  color: #d48806;
}

.status-SUCCESS {
  background: #e6f7ec;
  color: #00b341;
}

.status-FAILED {
  background: #fff1f0;
  color: #f5222d;
}

.status-CANCELED {
  background: #f5f5f5;
  color: #8f959e;
}

/* 元信息 */
.item-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: #fafbfc;
  border-radius: 8rpx;
}

.meta-row {
  display: flex;
  font-size: 24rpx;
  line-height: 1.5;
}

.meta-label {
  width: 160rpx;
  flex-shrink: 0;
  color: #8f959e;
}

.meta-value {
  flex: 1;
  color: #1f2329;
  word-break: break-all;
}

.meta-value.mono {
  font-family: monospace;
  font-size: 22rpx;
}

.meta-value.err {
  color: #f5222d;
}

/* 操作按钮 */
.item-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: 1rpx solid transparent;
}

.action-primary {
  background: #e6f4ff;
  color: #1677ff;
  border-color: #91caff;
}

.action-warn {
  background: #fff7e6;
  color: #d48806;
  border-color: #ffd591;
}

.action-danger {
  background: #fff1f0;
  color: #f5222d;
  border-color: #ffa39e;
}

.action-text {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #8f959e;
}

/* 分页 */
.pager {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
  padding: 0 24rpx;
}

.pager-btn {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  color: #487ed9;
  border: 1rpx solid #487ed9;
  border-radius: 8rpx;
}

.pager-btn.disabled {
  color: #c9cdd4;
  border-color: #e8eaec;
}

.pager-info {
  font-size: 26rpx;
  color: #6b7280;
}