<!--miniprogram/pages/index/scheduledOp/scheduledOp.wxml-->
<!--
  2026-07-01: 移除 <wxs src="../../util/filter.wxs"> 和 ./status.wxs 引用
  全部展示字段改用 page ts 派生的 {{item.displayXxx}} (见 scheduledOp.ts buildDisplayItems)
  理由: .wxs 文件导致 IDE wxml Language Server stale 状态报红 (lib 3.15.2 / cache / dir cache 多路径)
  + 项目本来 .ts 主业, 不需要 WXML Script 这种中间语言。
-->

<page-meta>
  <navigation-bar front-color="#ffffff" background-color="#487ed9" title="定时操作 (测试版)" />
</page-meta>

<view class="page">
  <!-- 🧪 测试版 banner -->
  <view class="beta-banner">
    <view class="beta-icon">🧪</view>
    <view class="beta-text">
      <view class="beta-title">测试版功能</view>
      <view class="beta-sub">定时操作 (一次性延迟, 决策 18 第一阶段) — 仅在 prod worker 启动时自动触发, dev 模式请用「立即触发」验证</view>
    </view>
  </view>

  <view class="content">
    <!-- 创建入口 (导航回设备页选择指令 + 时间) -->
    <view class="create-row" bindtap="onCreateTap">
      <view class="create-icon">+</view>
      <view class="create-text">
        <view class="create-title">新建定时操作</view>
        <view class="create-sub">选指令 + 选未来时间, 后台 BullMQ 到点自动触发</view>
      </view>
      <view class="create-arrow">›</view>
    </view>

    <!-- 列表 -->
    <view wx:if="{{loading}}" class="state">加载中...</view>
    <view wx:elif="{{items.length === 0}}" class="state">暂无定时任务</view>
    <view wx:else class="list">
      <view wx:for="{{items}}" wx:key="_id" class="item">
        <view class="item-head">
          <view class="item-protocol">
            <text class="proto-name">{{item.protocol}}</text>
            <text class="pid">pid={{item.pid}}</text>
          </view>
          <view class="status-tag status-{{item.status}}">{{item.displayStatus}}</view>
        </view>

        <view class="item-meta">
          <view class="meta-row">
            <text class="meta-label">计划时间</text>
            <text class="meta-value">{{item.displayScheduledAt}}</text>
          </view>
          <view class="meta-row" wx:if="{{item.executedAt}}">
            <text class="meta-label">实际执行</text>
            <text class="meta-value">{{item.displayExecutedAt}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">指令内容</text>
            <text class="meta-value mono">{{item.content}}</text>
          </view>
          <view class="meta-row" wx:if="{{item.failReason}}">
            <text class="meta-label">失败原因</text>
            <text class="meta-value err">{{item.failReason}}</text>
          </view>
          <view class="meta-row" wx:if="{{item.notifiedChannels && item.notifiedChannels.length > 0}}">
            <text class="meta-label">通知通道</text>
            <text class="meta-value">{{item.displayChannels}}</text>
          </view>
          <view class="meta-row" wx:if="{{item.remark}}">
            <text class="meta-label">备注</text>
            <text class="meta-value">{{item.remark}}</text>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="item-actions">
          <block wx:if="{{item.status === 'PENDING'}}">
            <view class="action-btn action-warn" data-id="{{item._id}}" bindtap="onCancel">取消</view>
            <view class="action-btn action-primary" data-id="{{item._id}}" bindtap="onTrigger">立即触发</view>
          </block>
          <block wx:elif="{{item.status === 'SUCCESS' || item.status === 'FAILED' || item.status === 'CANCELED'}}">
            <view class="action-btn action-danger" data-id="{{item._id}}" bindtap="onDelete">删除</view>
          </block>
          <block wx:else>
            <view class="action-text">任务{{item.displayStatus}}中, 暂不可操作</view>
          </block>
        </view>
      </view>
    </view>

    <!-- 分页 -->
    <view wx:if="{{total > pageSize}}" class="pager">
      <view class="pager-btn {{page === 1 ? 'disabled' : ''}}" bindtap="onPrev">上一页</view>
      <text class="pager-info">{{page}} / {{totalPages}}</text>
      <view class="pager-btn {{page >= totalPages ? 'disabled' : ''}}" bindtap="onNext">下一页</view>
    </view>
  </view>
</view>
