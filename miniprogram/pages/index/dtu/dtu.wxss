/* miniprogram/pages/index/dtu/dtu.wxss */
page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  background: #f4f7fb;
  padding-bottom: 60rpx;
}

/* === Hero === */
.hero {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  padding: 36rpx 28rpx 28rpx;
  color: #ffffff;
}

.hero-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.hero-left {
  flex: 1;
  min-width: 0;
}

.hero-eyebrow {
  font-size: 22rpx;
  opacity: 0.85;
  margin-bottom: 4rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.3;
  letter-spacing: 1rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.88;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.hero-meta-dot {
  opacity: 0.55;
}

.hero-icon {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* === KPI === */
.kpi-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.kpi {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 16rpx;
  padding: 18rpx 16rpx;
  text-align: center;
}

.kpi-num {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.1;
  font-family: -apple-system, "DIN Alternate", "Helvetica Neue", sans-serif;
  color: #ffffff;
}

.kpi-num.is-online {
  color: #2f9e57;
}

.kpi-num.is-offline {
  color: #ffd54f;
}

.kpi-label {
  font-size: 20rpx;
  opacity: 0.85;
  margin-top: 6rpx;
  color: #ffffff;
}

/* === Card 容器 === */
.card {
  margin: 20rpx 20rpx 0;
  background: #ffffff;
  border: 1rpx solid #e9ecf3;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(40, 60, 110, 0.05);
  overflow: hidden;
}

.card-title {
  padding: 20rpx 24rpx 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #1a2438;
  border-bottom: 1rpx solid #f0f2f7;
}

/* === 设备信息行 === */
.info-row {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx;
  gap: 14rpx;
  min-height: 80rpx;
}

.info-row-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  background: #eef3fb;
  color: #487ed9;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1;
}

.info-row-label {
  font-size: 26rpx;
  color: #3a4256;
  font-weight: 500;
  flex-shrink: 0;
  min-width: 100rpx;
}

.info-row-value {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #1a2438;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-row-value-edit {
  padding: 0;
  text-align: right;
}

.info-row-value-row {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
}

.info-row-empty {
  color: #c0c5d2;
  font-size: 24rpx;
}

.info-row-pill {
  display: inline-flex;
  align-items: center;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.4;
  font-weight: 500;
  flex-shrink: 0;
}

.info-row-pill.is-on {
  background: rgba(46, 207, 138, 0.12);
  color: #1aa86c;
}

.info-row-pill.is-off {
  background: rgba(229, 69, 69, 0.10);
  color: #e54545;
}

.info-mac {
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
  font-size: 24rpx;
  color: #2d3850;
  font-weight: 500;
}

.info-divider {
  height: 1rpx;
  background: #f0f2f7;
  margin: 0 24rpx;
}

/* === 地图卡 === */
.map-meta-row {
  display: flex;
  gap: 24rpx;
  padding: 18rpx 24rpx;
}

.map-meta-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  background: #f7f9fc;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
}

.map-meta-label {
  font-size: 20rpx;
  color: #8a93a6;
}

.map-meta-value {
  font-size: 26rpx;
  color: #1a2438;
  font-weight: 500;
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
}

.loc-detail {
  padding: 0 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.loc-detail-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.loc-detail-label {
  font-size: 22rpx;
  color: #8a93a6;
  flex-shrink: 0;
  padding-top: 2rpx;
}

.loc-detail-value {
  flex: 1;
  font-size: 24rpx;
  color: #2d3850;
  line-height: 1.5;
  word-break: break-all;
}

.map {
  width: 100%;
  height: 360rpx;
  border-top: 1rpx solid #f0f2f7;
}

/* === 设备列表 === */
.section {
  margin: 20rpx 20rpx 0;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a2438;
  margin: 4rpx 0 4rpx 4rpx;
}

/* === Empty === */
.empty {
  text-align: center;
  padding: 80rpx 0 40rpx;
  background: #ffffff;
  border: 1rpx solid #e9ecf3;
  border-radius: 16rpx;
  margin-top: 16rpx;
  color: #8a93a6;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #3a4256;
  margin-bottom: 6rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: #8a93a6;
}

/* === 设备卡（与 manageDev 一致） === */
.dev-card {
  position: relative;
  display: flex;
  align-items: stretch;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-top: 16rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 4rpx 20rpx rgba(40, 60, 110, 0.06);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.dev-card:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 8rpx rgba(40, 60, 110, 0.12);
}

.dev-card-status {
  width: 6rpx;
  flex-shrink: 0;
  background: #d0d6e0;
}

.dev-card.is-online .dev-card-status {
  background: linear-gradient(180deg, #2ecf8a 0%, #1aa86c 100%);
}

.dev-card.is-offline .dev-card-status {
  background: linear-gradient(180deg, #ff6b6b 0%, #e54545 100%);
}

.dev-card-main {
  flex: 1;
  min-width: 0;
  padding: 22rpx 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dev-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.dev-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  flex: 1;
}

.dev-pic-box {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 10rpx;
  background: linear-gradient(135deg, #fafbfd 0%, #f1f4f9 100%);
}

.dev-pic-img {
  width: 100%;
  height: 100%;
}

.dev-pic-emoji {
  font-size: 48rpx;
  line-height: 1;
  opacity: 0.85;
}

.dev-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2438;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dev-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  flex-shrink: 0;
  font-weight: 500;
}

.dev-pill.is-online {
  background: rgba(46, 207, 138, 0.12);
  color: #1aa86c;
}

.dev-pill.is-offline {
  background: rgba(229, 69, 69, 0.12);
  color: #e54545;
}

.dev-pill-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.dev-pill.is-online .dev-pill-dot {
  background: #2ecf8a;
}

.dev-pill.is-offline .dev-pill-dot {
  background: #e54545;
}

.dev-card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 20rpx;
}

.dev-meta-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-size: 24rpx;
  min-width: 0;
}

.dev-meta-label {
  color: #8a93a6;
  font-size: 22rpx;
  flex-shrink: 0;
}

.dev-meta-value {
  color: #2d3850;
  font-weight: 500;
  max-width: 280rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dev-card-foot {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 2rpx;
}

.dev-foot-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #c0c5d2;
  flex-shrink: 0;
}

.dev-foot-time {
  font-size: 20rpx;
  color: #7c8595;
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
}
