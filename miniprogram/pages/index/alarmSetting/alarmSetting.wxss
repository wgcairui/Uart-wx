/* miniprogram/pages/index/alarmSetting/alarmSetting.wxss */
page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  padding-bottom: 120rpx;  /* 留出 sticky save bar 空间 */
  background: linear-gradient(to bottom, #487ed9 0%, #e9f3fb 320rpx, #f4f7fb 100%);
}

/* === Hero === */
.hero {
  position: relative;
  padding: 48rpx 32rpx 40rpx;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  z-index: 0;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 28rpx;
}

.hero-stats {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-top: 24rpx;
}

.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  font-family: -apple-system, "DIN Alternate", "Helvetica Neue", sans-serif;
  line-height: 1;
}

.stat-num.is-dirty {
  color: #ffd54f;
  font-size: 36rpx;
}

.stat-num.is-alarm {
  color: #ff7a7a;
}

.stat-num-sub {
  font-size: 22rpx;
  font-weight: 400;
  opacity: 0.75;
  margin-left: 2rpx;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 1rpx;
}

/* === Tab 切换 === */
.tabs-wrap {
  margin: 24rpx 24rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(40, 60, 110, 0.06);
  padding: 6rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tabs {
  display: flex;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #5a6478;
  border-radius: 12rpx;
  transition: all 0.15s ease;
}

.tab.is-active {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  color: #ffffff;
  font-weight: 500;
}

/* === 内容区 === */
.content {
  margin: 16rpx 24rpx 0;
}

.tab-panel {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(40, 60, 110, 0.08);
  overflow: hidden;
  padding-bottom: 16rpx;
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 24rpx 28rpx 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2438;
}

.section-meta {
  font-size: 22rpx;
  color: #8a93a6;
}

.param-card {
  margin: 0 24rpx 16rpx;
  background: #fafbfd;
  border-radius: 16rpx;
  overflow: hidden;
}

/* === 显示参数 toggle === */
.param-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #f0f2f7;
  background: #ffffff;
  transition: background 0.15s ease;
}

.param-row:last-child {
  border-bottom: none;
}

.param-row:active {
  background: #f4f7fb;
}

.param-row-left {
  flex: 1;
  min-width: 0;
}

.param-name {
  font-size: 28rpx;
  color: #2d3850;
}

.toggle {
  position: relative;
  width: 80rpx;
  height: 44rpx;
  background: #d8dde7;
  border-radius: 22rpx;
  transition: background 0.2s ease;
}

.toggle.is-on {
  background: #487ed9;
}

.toggle-thumb {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 36rpx;
  height: 36rpx;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  transition: left 0.2s ease;
}

.toggle.is-on .toggle-thumb {
  left: 40rpx;
}

/* === 限值 区间条 === */
.threshold-row {
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #f0f2f7;
  background: #ffffff;
}

.threshold-row:last-child {
  border-bottom: none;
}

.threshold-row:active {
  background: #f4f7fb;
}

.threshold-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.threshold-name {
  font-size: 28rpx;
  color: #2d3850;
  font-weight: 500;
}

.threshold-range {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-family: -apple-system, "DIN Alternate", "Helvetica Neue", sans-serif;
}

.threshold-min,
.threshold-max {
  font-size: 26rpx;
  color: #1a2438;
  font-weight: 600;
}

.threshold-sep {
  font-size: 22rpx;
  color: #8a93a6;
}

.threshold-unit {
  font-size: 22rpx;
  color: #8a93a6;
  font-weight: 400;
  margin-left: 4rpx;
}

.threshold-bar-track {
  position: relative;
  height: 8rpx;
  background: #f0f2f7;
  border-radius: 4rpx;
}

.threshold-bar-fill {
  position: absolute;
  top: 0;
  bottom: 0;
  background: linear-gradient(90deg, #487ed9 0%, #5fa1ff 100%);
  border-radius: 4rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin: 0 24rpx 16rpx;
  padding: 24rpx 0;
  background: #ffffff;
  border: 2rpx dashed #c8d0e0;
  border-radius: 16rpx;
  color: #487ed9;
  font-size: 28rpx;
}

.add-btn:active {
  background: #f4f7fb;
}

.add-icon {
  font-size: 36rpx;
  line-height: 1;
  font-weight: 300;
}

/* === 状态告警 pill === */
.alarm-row {
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #f0f2f7;
  background: #ffffff;
}

.alarm-row:last-child {
  border-bottom: none;
}

.alarm-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2533;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.alarm-name-warn {
  font-size: 20rpx;
  font-weight: 500;
  color: #8a93a6;
  background: #f4f7fb;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  line-height: 1.3;
  border: 1rpx solid #e9ecf3;
}

.alarm-row.is-all-unselected {
  /* "未选 = 不生效 = 中性" — 不加任何视觉冲击（去掉浅红背景） */
  /* 提示靠标题旁的"未选"灰标签承担 */
}

/* === 空选信息 banner（中性提示，空数组是合法状态） === */
.alarm-empty-banner {
  margin: 20rpx 0;
  padding: 16rpx 20rpx;
  background: #eef3fb;
  border-left: 6rpx solid #487ed9;
  border-radius: 12rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  box-shadow: 0 2rpx 6rpx rgba(72, 126, 217, 0.08);
}

.alarm-empty-banner-icon {
  font-size: 30rpx;
  line-height: 1.3;
  color: #487ed9;
  flex-shrink: 0;
  font-weight: 600;
}

.alarm-empty-banner-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.alarm-empty-banner-title {
  font-size: 26rpx;
  color: #1f2533;
  font-weight: 600;
  line-height: 1.4;
}

.alarm-empty-banner-sub {
  font-size: 22rpx;
  color: #5a6b85;
  line-height: 1.5;
}

.alarm-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.alarm-hint,
.threshold-hint {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin: 0 28rpx 20rpx;
  padding: 18rpx 20rpx;
  border-left: 6rpx solid;
  border-radius: 12rpx;
}

.alarm-hint {
  background: linear-gradient(135deg, #fff8e1 0%, #fff3c4 100%);
  border-left-color: #f0a020;
}

.threshold-hint {
  background: linear-gradient(135deg, #e8f4fd 0%, #d3e9fb 100%);
  border-left-color: #487ed9;
}

.alarm-hint-icon,
.threshold-hint-icon {
  font-size: 32rpx;
  line-height: 1;
  flex-shrink: 0;
}

.alarm-hint-body,
.threshold-hint-body {
  flex: 1;
  min-width: 0;
}

.alarm-hint-title,
.threshold-hint-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #2d3850;
  line-height: 1.4;
}

.alarm-hint-sub {
  font-size: 22rpx;
  color: #6b5a2c;
  margin-top: 6rpx;
  line-height: 1.5;
}

.threshold-hint-sub {
  font-size: 22rpx;
  color: #2c4a6b;
  margin-top: 6rpx;
  line-height: 1.5;
}

.alarm-hint-legend {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx 14rpx;
  margin-top: 12rpx;
  padding-top: 10rpx;
  border-top: 1rpx dashed rgba(240, 160, 32, 0.35);
}

.alarm-hint-dot {
  display: inline-block;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  vertical-align: middle;
}

.alarm-hint-dot-ok {
  background: #2f9e57;
}

.alarm-hint-dot-alert {
  background: #e54545;
}

.alarm-hint-legend-text {
  font-size: 22rpx;
  color: #5a6478;
  margin-right: 6rpx;
}

.alarm-pill {
  padding: 10rpx 22rpx;
  font-size: 24rpx;
  color: #e54545;
  background: rgba(229, 69, 69, 0.06);
  border-radius: 999rpx;
  line-height: 1;
  border: 2rpx solid #e54545;
  transition: all 0.15s ease;
}

.alarm-pill:active {
  transform: scale(0.96);
}

/* 选中 = 健康（绿）；未选中 = 告警（红，.alarm-pill 默认态） */
.alarm-pill.is-on {
  background: rgba(60, 178, 110, 0.08);
  color: #2f9e57;
  border-color: #2f9e57;
  font-weight: 500;
}

/* === 未选 row 的 pill — 中性灰（不暗示"告警"或"健康"） ===
   row 整体未生效时，pill 的红绿对比没意义（"未选"=后端合法空数组=该参数告警不触发）
   视觉降级到中性色，等用户点选第一个 pill 后 row 退出"未选"状态，pill 恢复红绿对比 */
.alarm-row.is-all-unselected .alarm-pill {
  color: #8a93a6;
  background: #fafbfd;
  border-color: #e9ecf3;
}

.alarm-row.is-all-unselected .alarm-pill:active {
  background: #f4f7fb;
  border-color: #c0c5d2;
}

.alarm-row.is-all-unselected .alarm-pill.is-on {
  background: #f4f7fb;
  color: #8a93a6;
  border-color: #c0c5d2;
  font-weight: 400;
}

/* === Sticky 保存条 === */
.save-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.save-bar-text {
  font-size: 26rpx;
  color: #5a6478;
}

.save-bar-btn {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  padding: 16rpx 40rpx;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 12rpx rgba(72, 126, 217, 0.3);
}

.save-bar-btn:active {
  transform: scale(0.98);
}
