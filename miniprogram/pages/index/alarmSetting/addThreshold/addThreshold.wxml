<!--miniprogram/pages/index/alarmSetting/addThreshold/addThreshold.wxml-->
<page-meta>
  <navigation-bar front-color="#ffffff" background-color="#487ed9" />
</page-meta>
<view class="page">
  <view class="hero">
    <view class="hero-bg"></view>
    <view class="hero-content">
      <view class="hero-label">新增参数限值</view>
      <view class="hero-title">{{name || '选择参数'}}</view>
    </view>
  </view>

  <view class="content">
    <!-- 参数选择 -->
    <view class="section">
      <view class="section-head">
        <text class="section-title">选择参数</text>
      </view>
      <view wx:if="{{columns.length > 0}}" class="picker-grid">
        <view wx:for="{{columns}}" wx:key="*this"
          class="picker-cell {{item === name ? 'is-active' : ''}}"
          data-name="{{item}}" bindtap="onPick">
          <text>{{item}}</text>
        </view>
      </view>
      <view wx:else class="empty">
        <text>无可选参数（所有参数都已配置）</text>
      </view>
    </view>

    <!-- 限值配置 -->
    <view wx:if="{{name}}" class="section">
      <view class="section-head">
        <text class="section-title">限值范围</text>
        <text wx:if="{{unit}}" class="section-unit">单位：{{unit}}</text>
      </view>
      <view class="param-card">
        <view class="param-row">
          <view class="param-row-label">最小值</view>
          <view class="param-row-value">
            <view class="stepper">
              <view class="stepper-btn" bindtap="onMinMinus">−</view>
              <text class="stepper-num">{{min}}</text>
              <view class="stepper-btn" bindtap="onMinPlus">+</view>
            </view>
          </view>
        </view>
        <view class="param-divider"></view>
        <view class="param-row">
          <view class="param-row-label">最大值</view>
          <view class="param-row-value">
            <view class="stepper">
              <view class="stepper-btn" bindtap="onMaxMinus">−</view>
              <text class="stepper-num">{{max}}</text>
              <view class="stepper-btn" bindtap="onMaxPlus">+</view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="save-bar">
    <view class="save-bar-btn {{!name ? 'is-disabled' : ''}}" bindtap="onSubmit">添加</view>
  </view>
</view>
