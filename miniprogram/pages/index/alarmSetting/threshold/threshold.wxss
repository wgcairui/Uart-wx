/* miniprogram/pages/index/alarmSetting/threshold/threshold.wxss */
page { background: #f4f7fb; }

.page {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background: linear-gradient(to bottom, #487ed9 0%, #e9f3fb 280rpx, #f4f7fb 100%);
}

.hero {
  position: relative;
  padding: 48rpx 32rpx 40rpx;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  z-index: 0;
}

.hero-content { position: relative; z-index: 1; }

.hero-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.content {
  margin: 16rpx 24rpx 0;
}

.param-card {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(40, 60, 110, 0.08);
  overflow: hidden;
}

.param-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx;
}

.param-row-label {
  font-size: 30rpx;
  color: #1a2438;
  font-weight: 500;
}

.param-row-value {
  display: flex;
  align-items: center;
}

.param-divider {
  height: 1rpx;
  background: #f0f2f7;
  margin: 0 32rpx;
}

.param-foot {
  padding: 16rpx 32rpx 24rpx;
  font-size: 22rpx;
  color: #8a93a6;
}

.stepper {
  display: flex;
  align-items: center;
  background: #f4f7fb;
  border-radius: 999rpx;
  overflow: hidden;
}

.stepper-btn {
  width: 72rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  color: #487ed9;
}

.stepper-btn:active {
  background: #e6e8ed;
}

.stepper-num {
  min-width: 120rpx;
  text-align: center;
  font-size: 32rpx;
  color: #1a2438;
  font-weight: 500;
  font-family: -apple-system, "DIN Alternate", "Helvetica Neue", sans-serif;
}

.hint {
  margin: 24rpx 0 0;
  padding: 20rpx 28rpx;
  background: rgba(72, 126, 217, 0.08);
  border-left: 6rpx solid #487ed9;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #487ed9;
  line-height: 1.6;
}

.save-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.save-bar-btn {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  padding: 22rpx 80rpx;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 12rpx rgba(72, 126, 217, 0.3);
}

.save-bar-btn:active {
  transform: scale(0.98);
}
