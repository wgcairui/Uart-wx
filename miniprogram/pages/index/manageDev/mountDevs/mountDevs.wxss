/* miniprogram/pages/index/manageDev/mountDevs/mountDevs.wxss */
page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  background: #f4f7fb;
  padding-bottom: 160rpx;
}

/* === Hero === */
.hero {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  padding: 36rpx 28rpx 28rpx;
  color: #ffffff;
}

.hero-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.hero-info {
  flex: 1;
  min-width: 0;
}

.hero-eyebrow {
  display: inline-block;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  opacity: 0.7;
  margin-bottom: 4rpx;
  text-transform: uppercase;
}

.hero-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.hero-name {
  font-size: 38rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  max-width: 420rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-meta {
  font-size: 22rpx;
  opacity: 0.85;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
}

.hero-meta-icon {
  font-size: 22rpx;
  line-height: 1;
  opacity: 0.9;
}

.hero-mac {
  letter-spacing: 0.5rpx;
}

/* === Hero 危险动作 === */
.hero-icon-btn {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.hero-icon-btn:active {
  background: rgba(255, 255, 255, 0.25);
}

.hero-icon-btn-text {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1;
}

.hero-icon-btn-danger {
  background: rgba(229, 69, 69, 0.32);
  border-color: rgba(255, 200, 200, 0.4);
}

.hero-icon-btn-danger:active {
  background: rgba(229, 69, 69, 0.5);
}

/* === 状态 pill（与 index/manageDev 一致） === */
.dev-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  flex-shrink: 0;
  font-weight: 500;
}

.dev-pill.is-online {
  background: rgba(46, 207, 138, 0.22);
  color: #bdf3d4;
}

.dev-pill.is-offline {
  background: rgba(255, 213, 79, 0.22);
  color: #ffe69c;
}

.dev-pill-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #ffffff;
}

.dev-pill.is-online .dev-pill-dot {
  background: #2ecf8a;
  box-shadow: 0 0 0 3rpx rgba(46, 207, 138, 0.3);
}

.dev-pill.is-offline .dev-pill-dot {
  background: #ffd54f;
}

/* === KPI === */
.kpi-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.kpi {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 16rpx;
  padding: 18rpx 16rpx;
  text-align: center;
}

.kpi-num {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.1;
  font-family: -apple-system, "DIN Alternate", "Helvetica Neue", sans-serif;
  color: #ffffff;
}

.kpi-num.is-online {
  color: #2ecf8a;
}

.kpi-num.is-offline {
  color: #ffd54f;
}

.kpi-label {
  font-size: 20rpx;
  opacity: 0.85;
  margin-top: 6rpx;
  color: #ffffff;
}

/* === List === */
.list {
  padding: 16rpx 20rpx 0;
}

/* === Empty === */
.empty {
  text-align: center;
  padding: 120rpx 0 60rpx;
  color: #8a93a6;
}

.empty-icon {
  font-size: 96rpx;
  opacity: 0.5;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #3a4256;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: #8a93a6;
}

/* === 设备卡片（与 index/manageDev 视觉一致） === */
.dev-card {
  position: relative;
  display: flex;
  align-items: stretch;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-top: 16rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 4rpx 20rpx rgba(40, 60, 110, 0.06);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.dev-card:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 8rpx rgba(40, 60, 110, 0.12);
}

.dev-card-status {
  width: 6rpx;
  flex-shrink: 0;
  background: #d0d6e0;
}

.dev-card.is-online .dev-card-status {
  background: linear-gradient(180deg, #2ecf8a 0%, #1aa86c 100%);
}

.dev-card.is-offline .dev-card-status {
  background: linear-gradient(180deg, #ff6b6b 0%, #e54545 100%);
}

.dev-card-main {
  flex: 1;
  min-width: 0;
  padding: 22rpx 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dev-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.dev-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  flex: 1;
}

.dev-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  background: #eef3fb;
  color: #487ed9;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1;
}

.dev-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2438;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dev-card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 20rpx;
}

.dev-meta-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-size: 24rpx;
  min-width: 0;
}

.dev-meta-label {
  color: #8a93a6;
  font-size: 22rpx;
  flex-shrink: 0;
}

.dev-meta-value {
  color: #2d3850;
  font-weight: 500;
  max-width: 240rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* === 行内删除按钮 === */
.dev-card-del {
  width: 96rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-left: 1rpx solid #f0f2f7;
  background: #fafbfd;
  transition: background 0.1s ease;
}

.dev-card-del:active {
  background: #ffe7e7;
}

.dev-card-del-icon {
  font-size: 32rpx;
  color: #c0c5d2;
  font-weight: 300;
  line-height: 1;
}

.dev-card-del:active .dev-card-del-icon {
  color: #e54545;
}

/* === 底部添加按钮 === */
.footer-add {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 28rpx 32rpx;
  background: linear-gradient(180deg, rgba(244, 247, 251, 0) 0%, #f4f7fb 60%);
}

.footer-add-btn {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  color: #ffffff;
  border-radius: 999rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 6rpx 20rpx rgba(72, 126, 217, 0.32);
  transition: transform 0.1s ease, box-shadow 0.1s ease;
}

.footer-add-btn:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 10rpx rgba(72, 126, 217, 0.22);
}

.footer-add-icon {
  font-size: 32rpx;
  font-weight: 300;
  line-height: 1;
}
