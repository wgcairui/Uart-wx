/* miniprogram/pages/index/manageDev/manageDev.wxss */
page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  background: #f4f7fb;
  padding-bottom: 160rpx;
}

/* === Hero === */
.hero {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  padding: 36rpx 28rpx 28rpx;
  color: #ffffff;
}

.hero-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.hero-meta {
  font-size: 22rpx;
  opacity: 0.88;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.hero-meta-dot {
  opacity: 0.55;
}

/* === KPI === */
.kpi-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.kpi {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 16rpx;
  padding: 18rpx 16rpx;
  text-align: center;
}

.kpi-num {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.1;
  font-family: -apple-system, "DIN Alternate", "Helvetica Neue", sans-serif;
  color: #ffffff;
}

.kpi-num.is-online {
  color: #2f9e57;
}

.kpi-num.is-offline {
  color: #ffd54f;
}

.kpi-label {
  font-size: 20rpx;
  opacity: 0.85;
  margin-top: 6rpx;
  color: #ffffff;
}

/* === List === */
.list {
  padding: 16rpx 20rpx 0;
}

/* === Empty === */
.empty {
  text-align: center;
  padding: 120rpx 0 60rpx;
  color: #8a93a6;
}

.empty-icon {
  font-size: 96rpx;
  opacity: 0.5;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #3a4256;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: #8a93a6;
}

/* === DTU 卡片（与 index dev-card 视觉一致） === */
.dev-card {
  position: relative;
  display: flex;
  align-items: stretch;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-top: 16rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 4rpx 20rpx rgba(40, 60, 110, 0.06);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.dev-card:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 8rpx rgba(40, 60, 110, 0.12);
}

.dev-card-status {
  width: 6rpx;
  flex-shrink: 0;
  background: #d0d6e0;
}

.dev-card.is-online .dev-card-status {
  background: linear-gradient(180deg, #2ecf8a 0%, #1aa86c 100%);
}

.dev-card.is-offline .dev-card-status {
  background: linear-gradient(180deg, #ff6b6b 0%, #e54545 100%);
}

.dev-card-main {
  flex: 1;
  min-width: 0;
  padding: 22rpx 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  border-right: 1rpx solid #f0f2f7;
}

.dev-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.dev-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  flex: 1;
}

.dev-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  background: #eef3fb;
  color: #487ed9;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1;
}

.dev-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2438;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dev-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  flex-shrink: 0;
  font-weight: 500;
}

.dev-pill.is-online {
  background: rgba(46, 207, 138, 0.12);
  color: #1aa86c;
}

.dev-pill.is-offline {
  background: rgba(229, 69, 69, 0.12);
  color: #e54545;
}

.dev-pill-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.dev-pill.is-online .dev-pill-dot {
  background: #2ecf8a;
}

.dev-pill.is-offline .dev-pill-dot {
  background: #e54545;
}

.dev-card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 20rpx;
}

.dev-meta-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-size: 24rpx;
  min-width: 0;
}

.dev-meta-item-mac {
  flex-basis: 100%;
}

.dev-meta-label {
  color: #8a93a6;
  font-size: 22rpx;
  flex-shrink: 0;
}

.dev-meta-value {
  color: #2d3850;
  font-weight: 500;
  max-width: 280rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dev-mac {
  font-family: "JetBrains Mono", "SF Mono", Menlo, monospace;
  font-size: 22rpx;
  color: #7c8595;
  font-weight: 400;
  max-width: 100%;
}

.dev-card-pic {
  width: 140rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: linear-gradient(135deg, #fafbfd 0%, #f1f4f9 100%);
}

/* 统一图片容器：占位 emoji 居中显示（无背景） */
.dev-pic-box {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.dev-pic-emoji {
  font-size: 60rpx;
  line-height: 1;
  opacity: 0.85;
}

/* === 底部添加按钮 === */
.footer-add {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 28rpx 32rpx;
  background: linear-gradient(180deg, rgba(244, 247, 251, 0) 0%, #f4f7fb 60%);
}

.footer-add-btn {
  background: linear-gradient(135deg, #487ed9 0%, #3158b8 100%);
  color: #ffffff;
  border-radius: 999rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 6rpx 20rpx rgba(72, 126, 217, 0.32);
  transition: transform 0.1s ease, box-shadow 0.1s ease;
}

.footer-add-btn:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 10rpx rgba(72, 126, 217, 0.22);
}

.footer-add-icon {
  font-size: 32rpx;
  font-weight: 300;
  line-height: 1;
}
